{
  "version": 2,
  "builds": [
    {
      "src": "alipay-backend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/alipay-backend/api/$1.js" },
    { "src": "/", "dest": "/alipay-backend/public/index.html" },
    { "src": "/(.*)", "dest": "/alipay-backend/public/$1" }
  ]
}

